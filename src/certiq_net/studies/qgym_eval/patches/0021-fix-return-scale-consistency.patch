diff --git a/RL/utils/rollout_buffer.py b/RL/utils/rollout_buffer.py
--- a/RL/utils/rollout_buffer.py
+++ b/RL/utils/rollout_buffer.py
@@ -71,6 +71,11 @@
         print(f'compute_returns_and_advantage iteration: {self.iterations}')
 
         # normalize the reward values:
+        # Guard against the RC3 positive-feedback loop: clip raw rewards to a
+        # sane per-step range before GAE.  The single-env (non-batched) path
+        # is not clamped in env.py, so this is the single chokepoint that
+        # protects GAE/returns regardless of the env backend.
+        self.rewards = np.clip(self.rewards, -50.0, 0.0)
         rewards_mean = self.rewards.mean()
         rewards_std = self.rewards.std()
 
@@ -136,12 +141,24 @@
             self.adv_std = adv_std
 
         if self.normalize_value:
+            # Returns are normalized so the value-head target (~N(0,1))
+            # matches the value head's NORMALIZED output.  This is coherent
+            # with the ``rescale_v`` contract in ``CertiQSB3Policy``: the
+            # head predicts normalized returns, ``evaluate_values`` returns
+            # the normalized head (matches this target), and
+            # ``predict_values`` rescales the head to RAW scale only for the
+            # GAE bootstrap.  Rescaling returns to raw here broke that
+            # contract and created a GAE feedback loop that diverged the
+            # value head (44 -> 595 on the cloud run).
             self.returns_mean = returns_mean
-            self.returns_std = returns_std * self.var_scaler
+            # Cap returns_std so a runaway-queue rollout (RC3 feedback loop)
+            # cannot poison the normalization stat with an O(10^4) value.
+            self.returns_std = float(min(returns_std * self.var_scaler, 1e4))
 
-        # normalize the advantages and returns
+        # normalize the advantages (keeps the surrogate-gradient scale sane)
         self.advantages = (self.advantages - self.advantages.mean()) / self.adv_std
         self.advantages = np.clip(self.advantages, -10, 10)
+        # Returns normalized to match the value head's normalized output.
         self.returns = (self.returns - self.returns_mean) / self.returns_std
 
         ### log normalization stats
