diff --git a/main/env.py b/main/env.py
--- a/main/env.py
+++ b/main/env.py
@@ -593,5 +593,13 @@
 
         done = np.zeros(self.B, dtype=bool)
         reward = (-cost / 1000.0).detach().cpu().numpy()
+        # Clamp per-step reward so a transient runaway-queue event cannot
+        # inject an O(10^3) reward into GAE.  This is the source-side guard
+        # against the positive feedback loop (RC3): worse policy -> bigger
+        # queues -> bigger |reward| -> bigger returns std -> worse critic.
+        # 50.0 is ~5x the largest healthy per-step cost observed in eval
+        # (mean_queue_length ~37, event_time ~0.5 -> ~0.02/step after /1000),
+        # so it never touches normal training but stops the blowup.
+        reward = np.clip(reward, -50.0, 0.0)
         infos = [{} for _ in range(self.B)]
         return self.queues.detach().cpu().numpy(), reward, done, infos
